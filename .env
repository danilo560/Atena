# ============================================================================
# ATENA Ω - CONFIGURAÇÃO DE AMBIENTE (.env.example)
# Framework de Segurança com IA - Variáveis de Ambiente
# Versão: 5.0.0
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com seus valores reais
# 3. NUNCA commite o .env real no git!
# ============================================================================

# ============================================================================
# CONFIGURAÇÕES GERAIS DO SISTEMA
# ============================================================================

# Nome do ambiente (development, staging, production)
ENVIRONMENT=development

# Nível de debug (True/False)
DEBUG=True

# Secret Key para sessões e tokens (GERAR UMA NOVA!)
# Comando para gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-real-secret-key-in-production

# Diretório base do projeto
BASE_DIR=/home/user/atena

# Timezone do sistema
TIMEZONE=America/Sao_Paulo

# Idioma padrão
LANGUAGE=pt_BR

# ============================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ============================================================================

# Chave de criptografia mestra (32 bytes em base64)
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-this-to-a-32-byte-base64-key=

# Salt para hashes (16 bytes em hex)
# Gerar com: python -c "import secrets; print(secrets.token_hex(16))"
HASH_SALT=change-this-to-a-16-byte-hex-string

# JWT Secret (para autenticação)
JWT_SECRET_KEY=change-this-to-a-real-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting (requisições por minuto)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Session timeout (minutos)
SESSION_TIMEOUT=30
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# ============================================================================
# BANCO DE DADOS PRINCIPAL
# ============================================================================

# SQLite (padrão para desenvolvimento)
DATABASE_URL=sqlite:///data/atena.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# PostgreSQL (produção - descomente e configure)
# DATABASE_URL=postgresql://user:password@localhost:5432/atena
# DATABASE_SSL_MODE=require
# DATABASE_SSL_CA=/path/to/ca.pem
# DATABASE_SSL_CERT=/path/to/client-cert.pem
# DATABASE_SSL_KEY=/path/to/client-key.pem

# MySQL (alternativa)
# DATABASE_URL=mysql://user:password@localhost:3306/atena
# DATABASE_CHARSET=utf8mb4
# DATABASE_COLLATION=utf8mb4_unicode_ci

# ============================================================================
# BANCOS DE DADOS VETORIAIS (EMBEDDINGS)
# ============================================================================

# ChromaDB
CHROMA_PERSIST_DIRECTORY=/data/chromadb
CHROMA_COLLECTION_NAME=atena_vectors
CHROMA_HOST=localhost
CHROMA_PORT=8000

# FAISS
FAISS_INDEX_PATH=/data/faiss/index.faiss
FAISS_DIMENSION=768
FAISS_METRIC=IP  # Inner Product (ou L2)

# Annoy
ANNOY_INDEX_PATH=/data/annoy/index.ann
ANNOY_DIMENSION=768
ANNOY_METRIC=angular  # angular, euclidean, manhattan, dot
ANNOY_N_TREES=10

# HNSW
HNSW_INDEX_PATH=/data/hnsw/index.bin
HNSW_DIMENSION=768
HNSW_SPACE=cosine  # l2, ip, cosine
HNSW_EF_CONSTRUCTION=200
HNSW_M=16

# Milvus (se usar)
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_ALIAS=default
# MILVUS_COLLECTION=atena_vectors

# Qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# QDRANT_API_KEY=your-api-key
# QDRANT_COLLECTION=atena_vectors
# QDRANT_VECTOR_SIZE=768
# QDRANT_DISTANCE=Cosine

# Weaviate
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=your-api-key
# WEAVIATE_CLASS_NAME=AtenaVector

# Pinecone (cloud)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=atena-index
# PINECONE_DIMENSION=768
# PINECONE_METRIC=cosine

# ============================================================================
# CONFIGURAÇÕES DE IA E MODELOS
# ============================================================================

# Modelo padrão para embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu  # cpu, cuda, mps

# Modelo para classificação
CLASSIFIER_MODEL=bert-base-uncased
CLASSIFIER_MAX_LENGTH=512
CLASSIFIER_BATCH_SIZE=16

# Modelo para análise de código
CODE_MODEL=microsoft/codebert-base
CODE_MAX_LENGTH=512

# Modelo para análise de vulnerabilidades
VULN_MODEL=roberta-base

# Cache de modelos
MODELS_CACHE_DIR=/data/models
TRANSFORMERS_CACHE=/data/transformers
HF_HOME=/data/huggingface

# ============================================================================
# APIS DE IA EXTERNAS
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-organization-id
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-2.1
ANTHROPIC_MAX_TOKENS=100000

# Cohere
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command
COHERE_EMBEDDING_MODEL=embed-english-v2.0

# Google AI (PaLM/Gemini)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-pro

# HuggingFace Inference API
HF_API_TOKEN=hf_your-token
HF_API_URL=https://api-inference.huggingface.co/models/

# Replicate
REPLICATE_API_TOKEN=r8_your-token

# ============================================================================
# REDE E SCANNING
# ============================================================================

# Configurações de scan
SCAN_TIMEOUT=5
SCAN_THREADS=50
SCAN_DELAY=0.1
SCAN_JITTER=0.5
SCAN_MAX_PORTS=1000
SCAN_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36

# Proxy (opcional)
# HTTP_PROXY=http://proxy:8080
# HTTPS_PROXY=http://proxy:8080
# NO_PROXY=localhost,127.0.0.1

# Tor (para anonimato)
# TOR_PROXY=socks5://127.0.0.1:9050
# TOR_CONTROL_PORT=9051
# TOR_PASSWORD=your-tor-password

# VPN (opcional)
# VPN_CONFIG=/path/to/vpn.ovpn
# VPN_USER=username
# VPN_PASSWORD=password

# ============================================================================
# SERVIDORES E PORTAS
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True
API_SSL_CERT=/path/to/cert.pem
API_SSL_KEY=/path/to/key.pem

# Web Dashboard
WEB_HOST=0.0.0.0
WEB_PORT=3000
WEB_SECRET=your-web-secret

# WebSocket Server
WS_HOST=0.0.0.0
WS_PORT=8001
WS_MAX_CONNECTIONS=1000
WS_PING_INTERVAL=30

# ============================================================================
# REDIS (CACHE E FILAS)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_SSL=False
REDIS_TIMEOUT=5

# Cache TTL (segundos)
CACHE_TTL_DEFAULT=300
CACHE_TTL_SCAN_RESULTS=600
CACHE_TTL_EMBEDDINGS=86400  # 24 horas

# Filas (Celery/Redis)
CELERY_BROKER_URL=redis://:password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:password@localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=False
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# ============================================================================
# MENSAGERIA (RABBITMQ)
# ============================================================================

# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=guest
# RABBITMQ_PASSWORD=guest
# RABBITMQ_VHOST=/
# RABBITMQ_QUEUE=atena_tasks

# ============================================================================
# MONITORAMENTO E LOGGING
# ============================================================================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json ou text
LOG_FILE=/logs/atena.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_JSON_INCLUDE_STACK=True

# Sentry (erros)
SENTRY_DSN=https://your-key@sentry.io/project
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Prometheus
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key

# Elastic APM
# ELASTIC_APM_SERVER_URL=http://localhost:8200
# ELASTIC_APM_SECRET_TOKEN=your-token
# ELASTIC_APM_SERVICE_NAME=atena

# ============================================================================
# AUTENTICAÇÃO E USUÁRIOS
# ============================================================================

# Admin padrão (criado na primeira execução)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!  # MUDAR EM PRODUÇÃO!

# OAuth2
OAUTH2_PROVIDERS=google,github  # Lista separada por vírgula

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ============================================================================
# STORAGE E ARQUIVOS
# ============================================================================

# Local storage
STORAGE_TYPE=local  # local, s3, gcs, azure
STORAGE_PATH=/data/uploads
STORAGE_MAX_SIZE=104857600  # 100MB
STORAGE_ALLOWED_EXTENSIONS=.txt,.pdf,.json,.csv

# AWS S3 (se usar)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=atena-bucket
# AWS_S3_ENDPOINT=https://s3.amazonaws.com

# Google Cloud Storage
# GCS_BUCKET_NAME=atena-bucket
# GCS_PROJECT_ID=your-project-id
# GCS_CREDENTIALS_PATH=/path/to/credentials.json

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string
# AZURE_CONTAINER_NAME=atena-container

# ============================================================================
# EMAIL E NOTIFICAÇÕES
# ============================================================================

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_TIMEOUT=30

# Email padrão
DEFAULT_FROM_EMAIL=noreply@atena.com
DEFAULT_TO_EMAIL=admin@atena.com

# Notificações
NOTIFICATION_EMAIL_ENABLED=True
NOTIFICATION_SLACK_ENABLED=False
NOTIFICATION_DISCORD_ENABLED=False
NOTIFICATION_TELEGRAM_ENABLED=False

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#alerts

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ============================================================================
# BACKUP E MANUTENÇÃO
# ============================================================================

# Backup
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Todos os dias às 2AM
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESS=True
BACKUP_ENCRYPT=True
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key

# Limpeza automática
CLEANUP_ENABLED=True
CLEANUP_LOGS_DAYS=7
CLEANUP_TEMP_DAYS=1
CLEANUP_CACHE_DAYS=30

# ============================================================================
# FEATURES FLAGS (ATIVAR/DESATIVAR MÓDULOS)
# ============================================================================

# Módulos principais
FEATURE_SCANNER=True
FEATURE_EXPLOITER=True
FEATURE_AI=True
FEATURE_REPORTING=True
FEATURE_API=True
FEATURE_WEB_DASHBOARD=True

# Módulos específicos
FEATURE_WEB_SCAN=True
FEATURE_NETWORK_SCAN=True
FEATURE_VULN_DB=True
FEATURE_ML_TRAINING=False
FEATURE_REINFORCEMENT_LEARNING=False
FEATURE_MULTI_AGENT=False

# Modo stealth
STEALTH_MODE=True
STEALTH_EVASION_LEVEL=medium  # low, medium, high, paranoid
STEALTH_JITTER_ENABLED=True
STEALTH_RANDOM_SOURCE_PORT=True
STEALTH_FRAGMENT_PACKETS=False

# ============================================================================
# LICENÇA E REGISTRO
# ============================================================================

# Licença do produto
LICENSE_KEY=your-license-key
LICENSE_TYPE=enterprise  # community, professional, enterprise
LICENSE_EXPIRY=2026-12-31

# Registro (para telemetria - opcional)
TELEMETRY_ENABLED=False
TELEMETRY_URL=https://telemetry.atena.com
REGISTRATION_ID=your-registration-id

# ============================================================================
# SEGURANÇA ADICIONAL
# ============================================================================

# Web Application Firewall (WAF)
WAF_ENABLED=True
WAF_MODE=block  # log, block
WAF_RULESET=owasp

# Intrusion Detection System (IDS)
IDS_ENABLED=True
IDS_MODE=monitor  # monitor, active
IDS_RULESET=/etc/snort/rules

# Fail2ban
FAIL2BAN_ENABLED=True
FAIL2BAN_MAX_RETRIES=5
FAIL2BAN_BAN_TIME=3600

# ============================================================================
# METADADOS E INFORMAÇÕES
# ============================================================================

# Informações da aplicação
APP_NAME=ATENA
APP_VERSION=5.0.0
APP_BUILD=20260222
APP_COPYRIGHT="Copyright © 2026 Danilo Gomes"

# Contato
CONTACT_EMAIL=danilo@atena.com
CONTACT_WEBSITE=https://atena.com
CONTACT_GITHUB=https://github.com/danilo/atena
CONTACT_TWITTER=@atena

# ============================================================================
# ⚠️ AVISOS DE SEGURANÇA
# ============================================================================

# LEMBRETES (NÃO MODIFICAR ESTAS LINHAS)
# NUNCA COMMITAR ESTE ARQUIVO COM VALORES REAIS!
# SEMPRE USAR .env.example COMO TEMPLATE
# MUDAR TODAS AS SENHAS E CHAVES EM PRODUÇÃO!
# USAR AMBIENTES DIFERENTES PARA DEV/PROD!

# ============================================================================
# FIM DAS CONFIGURAÇÕES
# ============================================================================
